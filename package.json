{
  "name": "2048-game",
  "version": "1.0.0",
  "description": "A 2048 game implementation",
  "main": "index.html",
  "scripts": {
    "test": "node tests/test_runner.js",
    "coverage": "c8 npm test",
    "coverage:html": "c8 --reporter=html npm test",
    "coverage:text": "c8 --reporter=text npm test"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "jsdom": "^29.1.1"
  },
  "c8": {
    "include": [
      "js/**/*.js"
    ],
    "exclude": [
      "test/**",
      "node_modules/**"
    ],
    "reporter": [
      "text",
      "html"
    ],
    "all": true
  },
  "dependencies": {
    "canvas": "^3.2.3"
  }
}
